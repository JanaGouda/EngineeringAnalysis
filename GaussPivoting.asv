clc; 
clear;

A = input('Enter your coefficient matrix');
B = input('Enter source vector');

N = length(B);
X = zeros(N,1);

Aug = [A B];

for j = 1 : N - 1

    %Partial Pivoting
    [M,P] = max(abs(Aug(j:N,j)));

    C = Aug(j,:);
    Aug(j,:) = Aug(P+j-1,:);
    Aug(P+j-1,:) = C;
    %echlon form 

    for i = j + 1 : N
        m = Aug(i,j)/Aug(j,j);
        Aug(i,:) = Aug(i,:) - m*Aug(j,:);
    end  
end
X(N) = Aug(N,N+1)/Aug(N,N);

